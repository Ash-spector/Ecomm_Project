@model Ecomm_Project.Models.Category
@{
    var title = Model.id != 0 ? "Edit Category" : "Create Category";
}

<form method="post">
    @if (Model.id != 0)
    {
        <input type="hidden" asp-for="@Model.id" />
    }

    <div class="col-10 border-bottom">
        <h2 class="text-center text-info">@title</h2>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-8">
        <div class="form-group row p-2 m-2">
            <div class="col-4">
                <label asp-for="Name"></label>
            </div>
            <div class="col-8">
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group row p-2 m-2">
            <div class="col-8 offset-4">
                @if (Model.id != 0)
                {
                    <partial name="_EditAndBackToListButtons" />
                }
                else
                {
                    <partial name="_CreateAndBackToListButtons" />
                }
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />  
}